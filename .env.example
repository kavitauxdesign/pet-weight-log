# Only used in local development by the Vite proxy and e2e script.
# Example:
# VITE_API_BASE_URL=http://localhost:8000

# Optional lightweight write protection for POST/PUT/DELETE.
# Must match WEIGHT_API_TOKEN on the PHP host.
VITE_WEIGHT_API_TOKEN=change-me

# UI password required before adding, editing, or deleting records.
# Note: VITE_ variables are exposed in the frontend bundle, so this is
# only a convenience gate and not real backend security.
VITE_ACTION_PASSWORD=change-me
